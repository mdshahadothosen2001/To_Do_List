#postgres db setup in docker
ALLOWED_HOSTS=localhost 127.0.0.1 0.0.0.0
DEBUG=1

# redis://[[username]:[password]]@localhost:6379/0
REDIS_CONNECTION=redis://:127001@redis:6379/0
REDIS_PWD=127001

DB_CONNECTION=postgres://daymanager_admin:daymanager_password@db_daymanager:5432/daymanager_db

#postgres container credentials
POSTGRES_DB=daymanager_db
POSTGRES_USER=daymanager_admin
POSTGRES_PASSWORD=daymanager_password